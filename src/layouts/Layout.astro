---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "آژانس خلاقیت وبیرو | خدمات طراحی سایت، سئو و برنامه‌نویسی" } = Astro.props;
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | وبیرو</title>
    <meta name="description" content={description} />
    
    <!-- Fonts (you'll need to add actual font files later) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
  </head>
  <body>
    <slot />
    
    <!-- Scripts -->
    <script>
      import AOS from 'aos';
      AOS.init({
        duration: 800,
        once: true,
        offset: 50,
      });
    </script>
  </body>
</html>