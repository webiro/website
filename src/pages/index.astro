---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import { clients } from '../data/clients';
---

<BaseLayout title="صفحه نخست">
  <Header />

  <!-- Hero Section -->
  <section class="min-h-[100dvh] flex items-center pt-10">
    <div class="container">
      <div class="max-w-5xl mx-auto text-center">
        <h1 class="text-6xl md:text-7xl font-bold tracking-tight mb-6">
          آژانس خلاقیت <span class="text-accent">وبیرو</span>
        </h1>

        <div class="mb-8">
          <img 
            src="https://webiro.ir/wp-content/uploads/2023/08/webiro-logo-wide.png" 
            alt="وبیرو" 
            class="h-16 mx-auto mb-8 opacity-90" 
          />
        </div>

        <p class="text-2xl text-text mb-10">قدم به قدم، از شروع ایده تا اجرای پروژه</p>

        <!-- Client Logos Carousel -->
        <div class="client-logos mb-12 py-4 border-y border-border">
          <div class="flex gap-x-16 text-lg text-faded">
            {clients.concat(clients).map(client => (
              <div class="px-4">{client}</div>
            ))}
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/request" class="btn btn-accent px-10 py-4 text-lg">ثبت تیکت</a>
          <a href="/portfolio" class="btn btn-primary px-10 py-4 text-lg">نمونه‌کارها</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-16 border-t border-border">
    <div class="container">
      <h2 class="text-center text-4xl font-bold mb-12">خدمات</h2>
      
      <section id="services" class="grid_Services">
        <!-- Content will be injected via JS later -->
      </section>
    </div>
  </section>

  <!-- Why Webiro -->
  <section class="py-20 bg-bg-alt">
    <div class="container max-w-4xl">
      <h2 class="text-4xl font-bold mb-6">چرا وبیرو را باید انتخاب کنید؟</h2>
      <p class="text-xl text-faded mb-8">جمعِ متخصص‌ها، اینجا جَمعِ!</p>
      
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <p class="mb-6">تیم وبیرو متشکل از طراحان، توسعه‌دهندگان و متخصصان سئو است که با تجربه‌ای بیش از ۸ سال در کنار شما هستند.</p>
          <a href="/request" class="btn btn-primary">دریافت مشاوره</a>
        </div>
        <div>
          <p class="mb-6">ما فقط یک آژانس نیستیم؛ شریک رشد کسب‌وکار شما هستیم. از ایده تا اجرا و پشتیبانی، همراهتان هستیم.</p>
          <a href="/portfolio" class="btn btn-accent">مشاهده نمونه‌کارها</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Power Across Iran -->
  <section class="py-16">
    <div class="container text-center max-w-3xl">
      <h2 class="text-4xl font-bold mb-4">قدرتی به وسعت ایران!</h2>
      <p class="text-lg text-faded">مشاوره و خدمات وبیرو به صورت آنلاین و حضوری در تمام نقاط ایران در دسترس است.</p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-bg-alt border-t border-border">
    <div class="container text-center">
      <h2 class="text-4xl font-bold mb-4">وقت تعریف‌کردنِ داستان شماست...</h2>
      <a href="/request" class="btn btn-accent mt-6 px-12 py-4 text-lg inline-block">
        دریافت مشاوره رایگان
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-card border-t border-border py-16">
    <div class="container grid md:grid-cols-4 gap-y-12 text-sm">
      <div>
        <div class="font-bold text-xl mb-4">وبیرو</div>
        <p class="text-faded">آژانس خلاقیت وبیرو</p>
      </div>
      
      <div>
        <div class="font-semibold mb-4">خدمات وبیرو</div>
        <div class="space-y-2 text-faded">
          <div>طراحی سایت</div>
          <div>برنامه‌نویسی</div>
          <div>سئو سایت</div>
        </div>
      </div>
      
      <div>
        <div class="font-semibold mb-4">سرویس‌های ما</div>
        <div class="space-y-2 text-faded">
          <div>طراحی UI/UX</div>
          <div>ربات تلگرام</div>
          <div>اپلیکیشن موبایل</div>
        </div>
      </div>
      
      <div>
        <div class="font-semibold mb-4">ارتباط با ما</div>
        <div class="text-faded space-y-1">
          <div>info@webiro.ir</div>
          <div class="mt-4">نماد اعتماد الکترونیکی</div>
        </div>
      </div>
    </div>
    
    <div class="container mt-12 pt-8 border-t border-border text-center text-xs text-faded">
      © {new Date().getFullYear()} وبیرو. تمام حقوق محفوظ است.
    </div>
  </footer>
</BaseLayout>